@page "/categories"
@inject AuthService Auth
@inject NavigationManager Nav
@inject CategoryService CategorySvc
@rendermode InteractiveServer

<PageTitle>Κατηγορίες - Supermarket</PageTitle>

@if (!Auth.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
@if (Auth.CurrentRole == AuthService.Role.Seller) { Nav.NavigateTo("/"); return; }

<div class="page-header">
    <h1>🗂️ Κατηγορίες</h1>
    <button class="btn-primary" @onclick="ShowCreate">+ Νέα Κατηγορία</button>
</div>

<div class="search-bar">
    <input class="form-input" placeholder="Αναζήτηση..." value="@_search" @oninput="OnSearch" />
</div>

@if (_message != "")
{
    <div class="@(_isError ? "alert-error" : "alert-success")">@_message</div>
}

<div class="table-container">
    <table class="data-table">
        <thead>
            <tr><th>#</th><th>Όνομα</th><th>Περιγραφή</th><th>Ημερομηνία</th><th>Ενέργειες</th></tr>
        </thead>
        <tbody>
            @foreach (var c in _categories)
            {
                <tr>
                    <td>@c.CatId</td>
                    <td>@c.CatName</td>
                    <td>@c.CatDesc</td>
                    <td>@c.Date.ToString("dd/MM/yyyy")</td>
                    <td>
                        <button class="btn-icon" @onclick="() => ShowEdit(c)">✏️</button>
                        <button class="btn-icon btn-danger" @onclick="() => ConfirmDelete(c)">🗑️</button>
                    </td>
                </tr>
            }
            @if (_categories.Count == 0)
            {
                <tr><td colspan="5" class="empty-row">Δεν βρέθηκαν κατηγορίες.</td></tr>
            }
        </tbody>
    </table>
</div>

@if (_showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>@(_editItem?.CatId > 0 ? "Επεξεργασία Κατηγορίας" : "Νέα Κατηγορία")</h3>
                <button class="modal-close" @onclick="CloseModal">✕</button>
            </div>
            <div class="modal-body">
                @if (_editItem != null)
                {
                    <div class="form-group">
                        <label>Όνομα *</label>
                        <input class="form-input" @bind="_editItem.CatName" />
                    </div>
                    <div class="form-group">
                        <label>Περιγραφή</label>
                        <textarea class="form-input" rows="3" @bind="_editItem.CatDesc"></textarea>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CloseModal">Άκυρο</button>
                <button class="btn-primary" @onclick="SaveCategory">Αποθήκευση</button>
            </div>
        </div>
    </div>
}

@if (_showDeleteConfirm)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal modal-sm" @onclick:stopPropagation>
            <div class="modal-header"><h3>Επιβεβαίωση Διαγραφής</h3></div>
            <div class="modal-body"><p>Διαγραφή κατηγορίας <strong>@_deleteItem?.CatName</strong>;</p></div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CloseModal">Άκυρο</button>
                <button class="btn-danger" @onclick="DeleteCategory">Διαγραφή</button>
            </div>
        </div>
    </div>
}

@code {
    private List<CategoryTbl> _categories = [];
    private string _search = "";
    private string _message = "";
    private bool _isError;
    private bool _showModal;
    private bool _showDeleteConfirm;
    private CategoryTbl? _editItem;
    private CategoryTbl? _deleteItem;

    protected override void OnInitialized() { if (Auth.IsAuthenticated) Load(); }
    private void Load() => _categories = CategorySvc.GetAll(_search);
    private void OnSearch(ChangeEventArgs e) { _search = e.Value?.ToString() ?? string.Empty; Load(); }

    private void ShowCreate() { _editItem = new CategoryTbl { Date = DateTime.Now }; _showModal = true; _message = ""; }

    private void ShowEdit(CategoryTbl c)
    {
        _editItem = new CategoryTbl { CatId = c.CatId, CatName = c.CatName, CatDesc = c.CatDesc, Date = c.Date };
        _showModal = true;
        _message = "";
    }

    private void ConfirmDelete(CategoryTbl c) { _deleteItem = c; _showDeleteConfirm = true; _message = ""; }

    private void SaveCategory()
    {
        if (_editItem == null) return;
        int? result = _editItem.CatId > 0 ? CategorySvc.Update(_editItem) : CategorySvc.Create(_editItem);
        _isError = result != 1;
        _message = result == 1 ? "Αποθηκεύτηκε!" : "Σφάλμα αποθήκευσης.";
        CloseModal(); Load();
    }

    private void DeleteCategory()
    {
        if (_deleteItem == null) return;
        int? result = CategorySvc.Delete(_deleteItem);
        _isError = result != 1;
        _message = result == 1 ? "Διαγράφηκε!" : "Σφάλμα διαγραφής.";
        CloseModal(); Load();
    }

    private void CloseModal() { _showModal = false; _showDeleteConfirm = false; _editItem = null; _deleteItem = null; }
}
