@inject AuthService Auth
@inject NavigationManager Nav

<nav class="nav-menu">
    <button type="button" class="nav-link @(IsActive("/") ? "active" : "")" @onclick='() => Nav.NavigateTo("/")'>
        <span class="nav-icon">📊</span> Dashboard
    </button>

    @if (Auth.CurrentRole == AuthService.Role.Admin || Auth.CurrentRole == AuthService.Role.SuperAdmin)
    {
        <div class="nav-section-label">Διαχείριση</div>

        <button type="button" class="nav-link @(IsActive("/products") ? "active" : "")" @onclick='() => Nav.NavigateTo("/products")'>
            <span class="nav-icon">📦</span> Προϊόντα
        </button>

        <button type="button" class="nav-link @(IsActive("/categories") ? "active" : "")" @onclick='() => Nav.NavigateTo("/categories")'>
            <span class="nav-icon">🗂️</span> Κατηγορίες
        </button>

        <button type="button" class="nav-link @(IsActive("/sellers") ? "active" : "")" @onclick='() => Nav.NavigateTo("/sellers")'>
            <span class="nav-icon">👤</span> Πωλητές
        </button>

        <button type="button" class="nav-link @(IsActive("/bills") ? "active" : "")" @onclick='() => Nav.NavigateTo("/bills")'>
            <span class="nav-icon">🧾</span> Παραστατικά
        </button>

        @if (Auth.CurrentRole == AuthService.Role.SuperAdmin)
        {
            <div class="nav-section-label">Σύστημα</div>
            <button type="button" class="nav-link @(IsActive("/database") ? "active" : "")" @onclick='() => Nav.NavigateTo("/database")'>
                <span class="nav-icon">🗄️</span> Βάση Δεδομένων
            </button>
        }
    }

    @if (Auth.CurrentRole == AuthService.Role.Seller)
    {
        <div class="nav-section-label">Πωλήσεις</div>

        <button type="button" class="nav-link @(IsActive("/products") ? "active" : "")" @onclick='() => Nav.NavigateTo("/products")'>
            <span class="nav-icon">📦</span> Προϊόντα
        </button>

        <button type="button" class="nav-link @(IsActive("/bills") ? "active" : "")" @onclick='() => Nav.NavigateTo("/bills")'>
            <span class="nav-icon">🧾</span> Παραστατικά
        </button>

        <button type="button" class="nav-link @(IsActive("/create-bill") ? "active" : "")" @onclick='() => Nav.NavigateTo("/create-bill")'>
            <span class="nav-icon">➕</span> Νέο Παραστατικό
        </button>
    }
</nav>

@code {
    private bool IsActive(string path) =>
        Nav.Uri.EndsWith(path, StringComparison.OrdinalIgnoreCase) ||
        (path == "/" && Nav.Uri.TrimEnd('/').Equals(Nav.BaseUri.TrimEnd('/')));
}
